{
  "name": "@coastalalpine/cat-mail",
  "version": "0.1.0",
  "description": "Privacy-first AI email agent - Coastal Alpine Tech Email Management System. NZ Privacy Act compliant, in-memory processing, zero data retention.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "email",
    "ai-agent",
    "inbox-management",
    "spam-filter",
    "automation"
  ],
  "author": "fivepanelhat",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3",
    "googleapis": "^131.0.0",
    "anthropic": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "vitest": "^1.0.0",
    "@types/jest": "^29.0.0"
  }
}
